{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "skilllint/schemas/codex/v1.json",
  "title": "Codex Platform Schema v1",
  "description": "Bundled schema snapshot for Codex platform files (.rules prefix_rule, AGENTS.md, SKILL.md). Accessed via importlib.resources.files() at runtime.",
  "version": "1.0.0",
  "platform": "codex",
  "file_types": {
    "prefix_rule": {
      "x-experimental": true,
      "known_fields": ["pattern", "decision", "justification", "match", "not_match"],
      "valid_decisions": ["allow", "prompt", "forbidden"],
      "required_fields": ["pattern"]
    },
    "agents_md": {
      "x-non-empty": true,
      "description": "AGENTS.md must exist and contain non-empty content"
    },
    "skill_md": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 64 },
        "description": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "license": { "type": "string" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": true
    }
  }
}
